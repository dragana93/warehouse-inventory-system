{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "rootDir": ".",
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "generated/prisma": ["./generated/prisma/client"]
    }
  },
  "include": ["src", "generated"],
  "exclude": ["node_modules", "dist"]
}
