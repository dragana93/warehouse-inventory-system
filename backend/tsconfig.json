{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "generated/prisma": ["./generated/prisma"]
    }
  },
  "include": ["src"]
}
